{
  "name": "ecommerce-sandbox-server",
  "version": "1.1.0",
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "scripts": {
    "client": "cd client && npm start",
    "server": "nodemon server.js",
    "build": "cd client && npm run build",
    "dev": "concurrently --kill-others-on-fail \"npm run server\" \"npm run client\"",
    "start": "node server.js",
    "heroku-postbuild": "cd client && npm install && npm install --only=dev --no-shrinkwrap && npm run build"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "body-parser": "^1.20.4",
    "compression": "^1.8.1",
    "cors": "2.8.5",
    "dotenv": "^8.2.0",
    "express": "^5.2.1",
    "firebase": "^12.12.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-redux": "^7.2.4",
    "react-router-dom": "^5.2.0",
    "react-scripts": "^5.0.1",
    "react-stripe-checkout": "^2.6.3",
    "redux": "^4.1.0",
    "redux-logger": "^3.0.6",
    "redux-persist": "^6.0.0",
    "redux-saga": "^1.1.3",
    "reselect": "^4.0.0",
    "sass": "^1.34.1",
    "stripe": "6.28.0",
    "styled-components": "^5.3.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}
